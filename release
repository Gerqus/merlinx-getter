#!/usr/bin/env bash

set -euo pipefail

readonly SCRIPT_NAME="$(basename "$0")"
readonly EXIT_USAGE=2
readonly EXIT_DEPENDENCY=3
readonly EXIT_PRECHECK=4
readonly EXIT_TESTS=5
readonly EXIT_VERSION=6
readonly EXIT_TAG=7

usage() {
    cat <<EOF
Usage:
  $SCRIPT_NAME --bump patch|minor|major [--dry-run]
  $SCRIPT_NAME --version X.Y.Z [--dry-run]
  $SCRIPT_NAME --help

Description:
  Performs strict preflight checks, computes a canonical tag (vX.Y.Z),
  creates an annotated git tag, and pushes only that tag to origin.

Options:
  --bump <patch|minor|major>  Bump from latest existing semver tag.
  --version <X.Y.Z>           Release an explicit semver version.
  --dry-run                   Run all checks and print outcome without tagging/pushing.
  -h, --help                  Show this help and exit.
EOF
}

log() {
    printf '%s\n' "$*"
}

die() {
    local code="$1"
    shift
    printf 'ERROR: %s\n' "$*" >&2
    exit "$code"
}

require_command() {
    local cmd="$1"
    command -v "$cmd" >/dev/null 2>&1 || die "$EXIT_DEPENDENCY" "Required command '$cmd' not found."
}

is_valid_semver() {
    local version="$1"
    [[ "$version" =~ ^([0-9]+)\.([0-9]+)\.([0-9]+)$ ]]
}

semver_gt() {
    local left="$1"
    local right="$2"
    local l_major l_minor l_patch r_major r_minor r_patch

    IFS=. read -r l_major l_minor l_patch <<<"$left"
    IFS=. read -r r_major r_minor r_patch <<<"$right"

    if (( l_major > r_major )); then
        return 0
    fi
    if (( l_major < r_major )); then
        return 1
    fi

    if (( l_minor > r_minor )); then
        return 0
    fi
    if (( l_minor < r_minor )); then
        return 1
    fi

    if (( l_patch > r_patch )); then
        return 0
    fi

    return 1
}

get_latest_semver() {
    local latest="0.0.0"
    local found=0
    local tag normalized

    while IFS= read -r tag; do
        normalized="$tag"
        if [[ "$normalized" == v* ]]; then
            normalized="${normalized#v}"
        fi

        if is_valid_semver "$normalized"; then
            if (( found == 0 )) || semver_gt "$normalized" "$latest"; then
                latest="$normalized"
                found=1
            fi
        fi
    done < <(git tag --list)

    printf '%s\n' "$latest"
}

bump_semver() {
    local base="$1"
    local bump="$2"
    local major minor patch

    IFS=. read -r major minor patch <<<"$base"

    case "$bump" in
        patch)
            patch=$((patch + 1))
            ;;
        minor)
            minor=$((minor + 1))
            patch=0
            ;;
        major)
            major=$((major + 1))
            minor=0
            patch=0
            ;;
        *)
            die "$EXIT_USAGE" "Invalid bump level '$bump'. Use patch, minor, or major."
            ;;
    esac

    printf '%s.%s.%s\n' "$major" "$minor" "$patch"
}

assert_clean_worktree() {
    if [[ -n "$(git status --porcelain)" ]]; then
        die "$EXIT_PRECHECK" "Working tree is not clean. Commit/stash/discard changes before releasing."
    fi
}

assert_on_main_branch() {
    local current_branch
    current_branch="$(git branch --show-current)"

    if [[ "$current_branch" != "main" ]]; then
        die "$EXIT_PRECHECK" "Releases are allowed only from 'main'. Current branch: '$current_branch'."
    fi
}

fetch_origin_with_tags() {
    log "Fetching origin and tags..."
    git fetch --prune --tags origin >/dev/null
}

assert_synced_with_origin_main() {
    local local_head remote_head diverged counts ahead behind

    local_head="$(git rev-parse HEAD)"
    remote_head="$(git rev-parse refs/remotes/origin/main 2>/dev/null || true)"

    if [[ -z "$remote_head" ]]; then
        die "$EXIT_PRECHECK" "Could not resolve refs/remotes/origin/main after fetch."
    fi

    if [[ "$local_head" != "$remote_head" ]]; then
        counts="$(git rev-list --left-right --count HEAD...origin/main)"
        ahead="${counts%%[[:space:]]*}"
        behind="${counts##*[[:space:]]}"
        diverged="Local main is not synced with origin/main (ahead=$ahead, behind=$behind)."
        die "$EXIT_PRECHECK" "$diverged Pull/rebase/push before releasing."
    fi
}

run_tests() {
    log "Running tests: composer test"
    if ! composer test; then
        die "$EXIT_TESTS" "Test suite failed. Release aborted."
    fi
}

assert_tag_available() {
    local tag="$1"

    if git show-ref --verify --quiet "refs/tags/$tag"; then
        die "$EXIT_TAG" "Tag '$tag' already exists locally."
    fi

    if git ls-remote --tags --refs origin "$tag" | grep -q .; then
        die "$EXIT_TAG" "Tag '$tag' already exists on origin."
    fi
}

create_and_push_tag() {
    local tag="$1"
    local message="release: $tag"

    log "Creating annotated tag: $tag"
    git tag -a "$tag" -m "$message"

    log "Pushing tag to origin: $tag"
    git push origin "refs/tags/$tag"
}

main() {
    local bump=""
    local explicit_version=""
    local dry_run=0

    require_command git
    require_command composer

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --bump)
                [[ $# -ge 2 ]] || die "$EXIT_USAGE" "Missing value for --bump."
                bump="$2"
                shift 2
                ;;
            --version)
                [[ $# -ge 2 ]] || die "$EXIT_USAGE" "Missing value for --version."
                explicit_version="$2"
                shift 2
                ;;
            --dry-run)
                dry_run=1
                shift
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                die "$EXIT_USAGE" "Unknown argument '$1'. Use --help for usage."
                ;;
        esac
    done

    if [[ -n "$bump" && -n "$explicit_version" ]]; then
        die "$EXIT_USAGE" "Use either --bump or --version, not both."
    fi
    if [[ -z "$bump" && -z "$explicit_version" ]]; then
        die "$EXIT_USAGE" "You must provide either --bump or --version."
    fi

    if [[ -n "$bump" && "$bump" != "patch" && "$bump" != "minor" && "$bump" != "major" ]]; then
        die "$EXIT_USAGE" "Invalid bump level '$bump'. Use patch, minor, or major."
    fi
    if [[ -n "$explicit_version" ]]; then
        is_valid_semver "$explicit_version" || die "$EXIT_VERSION" "Version '$explicit_version' is not valid semver (X.Y.Z)."
    fi

    assert_on_main_branch
    assert_clean_worktree
    fetch_origin_with_tags
    assert_synced_with_origin_main
    run_tests

    local latest_semver target_semver target_tag
    latest_semver="$(get_latest_semver)"

    if [[ -n "$bump" ]]; then
        target_semver="$(bump_semver "$latest_semver" "$bump")"
    else
        if ! semver_gt "$explicit_version" "$latest_semver"; then
            die "$EXIT_VERSION" "Version '$explicit_version' must be greater than latest tag version '$latest_semver'."
        fi
        target_semver="$explicit_version"
    fi

    target_tag="v$target_semver"
    assert_tag_available "$target_tag"

    if (( dry_run == 1 )); then
        log "Dry run successful."
        log "Latest version: $latest_semver"
        log "Next tag: $target_tag"
        exit 0
    fi

    create_and_push_tag "$target_tag"
    log "Release complete: $target_tag"
}

main "$@"
